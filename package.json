{
  "name": "typescript-lambda-project",
  "version": "1.0.0",
  "description": "TypeScript Lambda with CI/CD deployment",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --watchAll=false",
    "deploy": "cdk deploy",
    "synth": "cdk synth",
    "security:audit": "npm audit --audit-level=high",
    "security:sast": "eslint src/ --ext .ts",
    "security:scan": "npm run security:audit && npm run security:sast"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.119",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "aws-cdk-lib": "^2.90.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint-plugin-security": "^1.7.1",
    "ts-jest": "^29.1.0",
    "jest-junit": "^16.0.0"
  },
  "dependencies": {
    "aws-lambda": "^1.0.7"
  }
}